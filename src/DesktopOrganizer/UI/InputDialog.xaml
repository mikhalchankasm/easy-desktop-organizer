<Window x:Class="DesktopOrganizer.UI.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ввод"
        Width="360" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize" ShowInTaskbar="False" Topmost="True">
    <StackPanel Margin="14">
        <TextBlock x:Name="PromptText" Text="Значение:" Margin="0,0,0,6"/>
        <TextBox x:Name="ValueBox" FontSize="14" Padding="4"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="ОК" Width="80" Margin="0,0,8,0" IsDefault="True" Click="Ok_Click"/>
            <Button Content="Отмена" Width="80" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
