<Window x:Class="DesktopOrganizer.UI.BoxSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки коробки"
        Width="360" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize" ShowInTaskbar="False" Topmost="True">
    <StackPanel Margin="16">
        <TextBlock Text="Название:"/>
        <TextBox x:Name="NameBox" FontSize="14" Padding="4" Margin="0,4,0,0"/>

        <TextBlock Text="Цвет фона:" Margin="0,14,0,4"/>
        <WrapPanel x:Name="SwatchPanel"/>

        <TextBlock Text="Прозрачность:" Margin="0,14,0,0"/>
        <DockPanel Margin="0,4,0,0">
            <TextBlock x:Name="OpacityLabel" DockPanel.Dock="Right" Width="40"
                       TextAlignment="Right" VerticalAlignment="Center"/>
            <Slider x:Name="OpacitySlider" Minimum="0.3" Maximum="1.0"
                    SmallChange="0.05" LargeChange="0.1"
                    ValueChanged="OpacitySlider_ValueChanged"/>
        </DockPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="ОК" Width="84" Margin="0,0,8,0" IsDefault="True" Click="Ok_Click"/>
            <Button Content="Отмена" Width="84" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
