<Window x:Class="DesktopOrganizer.UI.BoxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Коробка"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        MinWidth="180" MinHeight="40"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        ContextMenuOpening="Window_ContextMenuOpening">

    <Window.ContextMenu>
        <ContextMenu/>
    </Window.ContextMenu>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Border x:Name="RootBorder" CornerRadius="10" Background="#CC1E242C"
            BorderBrush="#40FFFFFF" BorderThickness="1">
        <DockPanel>
            <!-- Заголовок коробки -->
            <Border x:Name="HeaderBar" DockPanel.Dock="Top" Height="32"
                    Background="#33000000" CornerRadius="9,9,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <DockPanel Margin="10,0,4,0">
                    <Button x:Name="CollapseButton" DockPanel.Dock="Right" Content="—"
                            Width="24" Height="22" Click="CollapseButton_Click"
                            Background="Transparent" Foreground="#CCFFFFFF" BorderThickness="0"
                            FontSize="12" Cursor="Hand" ToolTip="Свернуть/развернуть"/>
                    <Button x:Name="SettingsButton" DockPanel.Dock="Right" Content="⚙"
                            Width="24" Height="22" Click="SettingsButton_Click"
                            Background="Transparent" Foreground="#CCFFFFFF" BorderThickness="0"
                            FontSize="12" Cursor="Hand" ToolTip="Настройки коробки"/>
                    <TextBlock x:Name="TitleText" Text="Коробка" Foreground="White"
                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </DockPanel>
            </Border>

            <!-- Область элементов -->
            <ListBox x:Name="ItemsList"
                     Background="Transparent" BorderThickness="0" Margin="4"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     VirtualizingPanel.IsVirtualizing="False"
                     PreviewMouseLeftButtonDown="ItemsList_PreviewMouseLeftButtonDown"
                     PreviewMouseMove="ItemsList_PreviewMouseMove"
                     MouseDoubleClick="ItemsList_MouseDoubleClick">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="2"/>
                        <Setter Property="Margin" Value="2"/>
                        <Setter Property="ToolTip" Value="{Binding FullPath}"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Width="{Binding CellWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Orientation="Vertical">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMissing}" Value="True">
                                            <Setter Property="Opacity" Value="0.4"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Image Source="{Binding Icon}"
                                   Width="{Binding IconSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Height="{Binding IconSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Margin="0,4,0,2"/>
                            <TextBlock Text="{Binding Name}" Foreground="White" FontSize="11"
                                       TextAlignment="Center" TextWrapping="Wrap" MaxHeight="30"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Border>
</Window>
